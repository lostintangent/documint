{
  "name": "documint",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --hot playground/dev.ts",
    "build": "bun run scripts/build.ts",
    "test": "bun test",
    "lint": "oxlint .",
    "format": "oxfmt . '!test/goldens/**/*.md'",
    "typecheck": "tsc --noEmit",
    "benchmark": "bun run scripts/benchmarks/index.ts",
    "test:goldens": "bun test test/markdown/golden.test.ts"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4",
    "lucide-react": "^1.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/mdast": "^4.0.4",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.11"
}
