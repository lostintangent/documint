{
  "name": "documint",
  "version": "0.0.5",
  "files": [
    "dist/index.js",
    "dist/index.d.ts"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "bun --hot playground/index.html --hostname=0.0.0.0 --port=3003",
    "build:dev": "bun run scripts/build.ts",
    "build:prod": "bun run scripts/build.ts --prod",
    "build:playground": "bun run scripts/build.ts --playground",
    "test": "bun test",
    "lint": "oxlint .",
    "format": "oxfmt . '!test/goldens/**/*.md'",
    "typecheck": "tsc --noEmit",
    "benchmark": "bun run scripts/benchmarks/index.ts",
    "test:goldens": "bun test test/markdown/golden.test.ts"
  },
  "devDependencies": {
    "@chenglou/pretext": "^0.0.4",
    "@types/bun": "latest",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "dts-bundle-generator": "^9.5.1",
    "lucide-react": "^1.8.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "packageManager": "bun@1.3.11"
}
